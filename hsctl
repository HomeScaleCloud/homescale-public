#!/usr/bin/env bash
set -euo pipefail

HSCTL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export HSCTL_ROOT
HSCTL_REPO_ROOT="${HSCTL_REPO_ROOT:-$HOME/Repos/homescale}"
export HSCTL_REPO_ROOT

usage() {
    echo "Usage: hsctl <command> [subcommand] [args...]"
    echo ""
    echo "Commands:"
    for f in "$HSCTL_ROOT/hsctl.d/"*.sh; do
        [[ "$(basename "$f")" == _* ]] && continue
        echo "  $(basename "$f" .sh)"
    done
    exit 1
}

hsctl_update() {
    local repo="HomeScaleCloud/homescale"
    local raw_header="Accept: application/vnd.github.raw+json"
    local install_dir="$HOME/.local/bin"
    local modules_dir="$install_dir/hsctl.d"

    mkdir -p "$modules_dir"

    echo "Fetching hsctl..."
    gh api "repos/$repo/contents/hsctl" --header "$raw_header" > "$install_dir/hsctl"
    chmod +x "$install_dir/hsctl"

    echo "Fetching modules..."
    local modules
    modules=$(gh api "repos/$repo/contents/hsctl.d" | grep -o '"name":"[^"]*\.sh"' | cut -d'"' -f4)
    for module in $modules; do
        gh api "repos/$repo/contents/hsctl.d/$module" --header "$raw_header" > "$modules_dir/$module"
        echo "  $module"
    done

    echo "Installed to $install_dir"
}

[[ $# -eq 0 ]] && usage

cmd="$1"; shift

[[ "$cmd" == "--update" ]] && { hsctl_update; exit 0; }

module="$HSCTL_ROOT/hsctl.d/${cmd}.sh"

if [[ ! -f "$module" ]]; then
    echo "hsctl: unknown command '$cmd'" >&2
    usage
fi

# shellcheck source=/dev/null
lib="$HSCTL_ROOT/hsctl.d/_lib.sh"
[[ -f "$lib" ]] && source "$lib"

# shellcheck source=/dev/null
source "$module"
"${cmd}_main" "$@"
