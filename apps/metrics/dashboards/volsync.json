{
  "uid": "volsync",
  "title": "VolSync",
  "tags": [
    "volsync",
    "backup"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "id": 1,
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Out of Sync",
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(volsync_volume_out_of_sync{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"} == 1) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Volumes",
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(volsync_volume_out_of_sync{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"}) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Missed Intervals",
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(volsync_missed_intervals_total{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"}) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Avg Last Sync Duration",
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 3600
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg(volsync_sync_duration_seconds_sum{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"} / volsync_sync_duration_seconds_count{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"} > 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Volume Status",
      "id": 6,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "obj_name",
            "desc": false
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cluster"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "obj_name"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 250
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "obj_namespace"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "role"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "method"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "custom.width",
                "value": 120
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "color": "green",
                        "index": 0,
                        "text": "In Sync"
                      },
                      "1": {
                        "color": "red",
                        "index": 1,
                        "text": "Out of Sync"
                      }
                    }
                  }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "volsync_volume_out_of_sync{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"}",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "prometheus": true,
              "prometheus_replica": true,
              "service": true
            },
            "indexByName": {
              "obj_name": 1,
              "obj_namespace": 2,
              "role": 3,
              "method": 4,
              "Value": 5,
              "cluster": 0
            },
            "renameByName": {
              "Value": "Status"
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Sync Duration",
      "id": 7,
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Sync Duration per Volume",
      "id": 8,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(volsync_sync_duration_seconds_sum{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"}[$__rate_interval]) / rate(volsync_sync_duration_seconds_count{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"}[$__rate_interval]) > 0",
          "legendFormat": "{{obj_name}} / {{obj_namespace}} ({{role}})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "PVC Coverage",
      "id": 11,
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "panels": []
    },
    {
      "type": "table",
      "title": "Bound PVCs without a VolSync ReplicationSource",
      "description": "Bound PVCs that have no matching VolSync ReplicationSource. Not necessarily a problem \u2014 system PVCs, ephemeral storage, or intentionally unprotected volumes will appear here.",
      "id": 12,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Namespace",
            "desc": false
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cluster"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Namespace"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "PVC"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 280
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Storage Class"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "(\n  kube_persistentvolumeclaim_info{cluster=~\"$cluster\", persistentvolumeclaim!~\".*volsync.*\"}\n  * on(namespace, persistentvolumeclaim) group_left()\n  kube_persistentvolumeclaim_status_phase{cluster=~\"$cluster\", phase=\"Bound\"}\n)\nunless on(namespace, persistentvolumeclaim)\nlabel_replace(\n  label_replace(\n    volsync_volume_out_of_sync{cluster=~\"$cluster\", role=\"source\"},\n    \"namespace\", \"$1\", \"obj_namespace\", \"(.*)\"\n  ),\n  \"persistentvolumeclaim\", \"$1\", \"obj_name\", \"(.*)\"\n)",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "prometheus": true,
              "prometheus_replica": true,
              "service": true,
              "volumename": true
            },
            "indexByName": {
              "namespace": 1,
              "persistentvolumeclaim": 2,
              "storageclass": 3,
              "cluster": 0
            },
            "renameByName": {
              "namespace": "Namespace",
              "persistentvolumeclaim": "PVC",
              "storageclass": "Storage Class"
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Missed Intervals",
      "id": 9,
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Missed Sync Intervals",
      "id": 10,
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "increase(volsync_missed_intervals_total{cluster=~\"$cluster\", obj_namespace=~\"$namespace\"}[$__rate_interval])",
          "legendFormat": "{{obj_name}} / {{obj_namespace}} ({{role}})",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(volsync_volume_out_of_sync, cluster)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "cluster",
        "query": {
          "query": "label_values(volsync_volume_out_of_sync, cluster)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(volsync_volume_out_of_sync{cluster=~\"$cluster\"}, obj_namespace)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "namespace",
        "query": {
          "query": "label_values(volsync_volume_out_of_sync{cluster=~\"$cluster\"}, obj_namespace)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "allValue": ".*"
      }
    ]
  }
}
