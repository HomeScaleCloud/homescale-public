            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "min(up{job=\"netbird-operator\", cluster=~\"$cluster\"})",
          "instant": true,
          "refId": "A"
        }
      ]
    },
