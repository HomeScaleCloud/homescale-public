{
  "uid": "omni",
  "title": "Omni",
  "tags": ["omni", "talos", "siderolink"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "annotations": { "list": [] },
  "editable": true,
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(up{namespace=\"omni\"}, cluster)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "cluster",
        "query": { "query": "label_values(up{namespace=\"omni\"}, cluster)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "id": 1,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Omni Up",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "up{namespace=\"omni\", cluster=~\"$cluster\"}", "instant": true, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Total Machines",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "area", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_machines{cluster=~\"$cluster\"}", "instant": true, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Connected Machines",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_connected_machines{cluster=~\"$cluster\"}", "instant": true, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Running Clusters",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "area", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_clusters{phase=\"RUNNING\", cluster=~\"$cluster\"}", "instant": true, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Running Cluster Machines",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "area", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_cluster_machines{stage=\"RUNNING\", cluster=~\"$cluster\"}", "instant": true, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Users",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(omni_users{cluster=~\"$cluster\"})", "instant": true, "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "EOS Warning",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "displayName": "Machines past/near Talos EOS"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_machines_talos_version_end_of_support{cluster=~\"$cluster\"}", "legendFormat": "past EOS", "instant": true, "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_machines_approaching_talos_version_end_of_support{cluster=~\"$cluster\"}", "legendFormat": "approaching EOS", "instant": true, "refId": "B" }
      ]
    },
    {
      "type": "stat",
      "title": "SQLite DB Size",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "area", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_sqlite_db_size_bytes{cluster=~\"$cluster\"}", "instant": true, "refId": "A" }]
    },
    {
      "type": "row",
      "title": "Machines",
      "id": 20,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Machines",
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 6 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_machines{cluster=~\"$cluster\"}", "legendFormat": "total", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_connected_machines{cluster=~\"$cluster\"}", "legendFormat": "connected", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cluster Machines by Stage",
      "id": 22,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 6 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_cluster_machines{cluster=~\"$cluster\"}", "legendFormat": "{{stage}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Machine Platforms",
      "id": 23,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_machine_platforms{cluster=~\"$cluster\"} > 0", "legendFormat": "{{platform}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Machine Security",
      "id": 24,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_machine_secure_boot_status{cluster=~\"$cluster\"}", "legendFormat": "secure-boot={{enabled}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_machine_uki_status{cluster=~\"$cluster\"}", "legendFormat": "uki={{booted_with_uki}}", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "Clusters",
      "id": 30,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Clusters by Phase",
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_clusters{cluster=~\"$cluster\"}", "legendFormat": "{{phase}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Active Users (7d / 30d)",
      "id": 32,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_active_users{cluster=~\"$cluster\"}", "legendFormat": "{{type}} ({{window}})", "refId": "A" }]
    },
    {
      "type": "row",
      "title": "SideroLink",
      "id": 40,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "SideroLink Traffic",
      "id": 41,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] } },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_siderolink_received_bytes_total{cluster=~\"$cluster\"}[5m])", "legendFormat": "rx", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_siderolink_sent_bytes_total{cluster=~\"$cluster\"}[5m])", "legendFormat": "tx", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "SideroLink Last Handshake (histogram)",
      "id": 42,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, rate(omni_siderolink_last_handshake_seconds_bucket{cluster=~\"$cluster\"}[5m]))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, rate(omni_siderolink_last_handshake_seconds_bucket{cluster=~\"$cluster\"}[5m]))", "legendFormat": "p90", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, rate(omni_siderolink_last_handshake_seconds_bucket{cluster=~\"$cluster\"}[5m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "row",
      "title": "etcd Backup",
      "id": 50,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "etcd Backup Transfer Rate",
      "id": 51,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] } },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_etcdbackup_store_transferred_bytes_total{cluster=~\"$cluster\"}[5m])", "legendFormat": "upload", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_etcdbackup_store_downloaded_bytes_total{cluster=~\"$cluster\"}[5m])", "legendFormat": "download", "refId": "B" }
      ]
    },
    {
      "type": "row",
      "title": "COSI Runtime / Controllers",
      "id": 60,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Controller Reads & Writes",
      "id": 61,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_runtime_controller_reads{cluster=~\"$cluster\"}[5m])", "legendFormat": "read:{{controller}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_runtime_controller_writes{cluster=~\"$cluster\"}[5m])", "legendFormat": "write:{{controller}}", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Controller Activity",
      "id": 62,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_runtime_qcontroller_processed{cluster=~\"$cluster\"}[5m])", "legendFormat": "processed:{{controller}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Controller Busy Time",
      "id": 63,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_runtime_qcontroller_map_busy_seconds{cluster=~\"$cluster\"}[5m])", "legendFormat": "map:{{controller}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(omni_runtime_qcontroller_reconcile_busy_seconds{cluster=~\"$cluster\"}[5m])", "legendFormat": "reconcile:{{controller}}", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Controller Queue Length",
      "id": 64,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "omni_runtime_qcontroller_queue_length{cluster=~\"$cluster\"} > 0", "legendFormat": "{{controller}}", "refId": "A" }
      ]
    },
    {
      "type": "row",
      "title": "etcd (embedded)",
      "id": 70,
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "etcd DB Size",
      "id": 71,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 59 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "etcd_mvcc_db_total_size_in_bytes{cluster=~\"$cluster\"}", "legendFormat": "allocated", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "etcd_mvcc_db_total_size_in_use_in_bytes{cluster=~\"$cluster\"}", "legendFormat": "in-use", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "etcd Operations Rate",
      "id": 72,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 59 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(etcd_mvcc_put_total{cluster=~\"$cluster\"}[5m])", "legendFormat": "puts", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(etcd_mvcc_range_total{cluster=~\"$cluster\"}[5m])", "legendFormat": "ranges", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(etcd_mvcc_txn_total{cluster=~\"$cluster\"}[5m])", "legendFormat": "txns", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(etcd_mvcc_delete_total{cluster=~\"$cluster\"}[5m])", "legendFormat": "deletes", "refId": "D" }
      ]
    },
    {
      "type": "timeseries",
      "title": "etcd WAL Fsync Latency",
      "id": 73,
