{
  "annotations": {"list": []},
  "description": "Rack PDU health — input voltage, bank load, and per-outlet state",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 205},
              {"color": "red", "value": 221}
            ]
          },
          "mappings": [
            {
              "type": "range",
              "options": {"from": 205, "to": 220, "result": {"text": "Normal", "index": 0}}
            },
            {
              "type": "range",
              "options": {"from": 0, "to": 204.99, "result": {"text": "Warning", "index": 1}}
            },
            {
              "type": "range",
              "options": {"from": 220.01, "to": 300, "result": {"text": "Warning", "index": 2}}
            }
          ],
          "unit": "volt"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 5, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apc_rpdu_input_voltage_volts{cluster=\"$cluster\", job=~\"$job\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Input Voltage",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "orange", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "mappings": [],
          "unit": "percent",
          "decimals": 0,
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 5, "x": 5, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apc_rpdu_bank_load_deciamps{cluster=\"$cluster\", job=~\"$job\"} / 10 / apc_rpdu_bank_near_overload_threshold_amps{cluster=\"$cluster\", job=~\"$job\"} * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Bank Load",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 4,
      "title": "Trends",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "spanNulls": false},
          "unit": "amp",
          "decimals": 1
        },
        "overrides": [
          {
            "matcher": {"id": "byFrameRefID", "options": "threshold"},
            "properties": [
              {"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}},
              {"id": "custom.lineStyle", "value": {"dash": [8, 4], "fill": "dash"}},
              {"id": "custom.lineWidth", "value": 1},
              {"id": "custom.fillOpacity", "value": 0}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 5,
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apc_rpdu_bank_load_deciamps{cluster=\"$cluster\", job=~\"$job\"} / 10",
          "legendFormat": "{{job}}",
          "refId": "load"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apc_rpdu_bank_near_overload_threshold_amps{cluster=\"$cluster\", job=~\"$job\"}",
          "legendFormat": "{{job}} near-overload threshold",
          "refId": "threshold"
        }
      ],
      "title": "Bank Load (Amps)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "spanNulls": false},
          "unit": "volt",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 6,
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apc_rpdu_input_voltage_volts{cluster=\"$cluster\", job=~\"$job\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Input Voltage",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 7,
      "title": "Outlets",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 2}
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {"text": "Off", "index": 0},
                "2": {"text": "On", "index": 1}
              }
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 15},
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "apc_rpdu_outlet_state{cluster=\"$cluster\", job=~\"$job\"}",
          "legendFormat": "{{job}} — {{outlet_name}}"
        }
      ],
      "title": "Outlet States",
      "type": "stat"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["pdu", "power", "infrastructure"],
