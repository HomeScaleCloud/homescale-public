{
  "extends": [
    "config:recommended"
  ],
  "baseBranches": [
    "main"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "pin",
        "digest",
        "patch"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchManagers": ["terraform"],
      "semanticCommitScope": "infra"
    },
    {
      "matchManagers": ["argocd", "kubernetes", "dockerfile"],
      "semanticCommitScope": "apps"
    },
    {
      "matchManagers": ["github-actions"],
      "semanticCommitScope": "deps"
    }
  ],
  "argocd": {
    "fileMatch": [
      "apps/.+/[^/]+-argocd\\.yaml$"
    ]
  },
  "terraform": {
    "fileMatch": [
      "infra/terraform/.*\\.tf$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "apps/.+/.+\\.yaml$"
    ]
  },
  "github-actions": {
    "fileMatch": [
      ".gitea/workflows/.*\\.yaml$"
    ]
  },
  "dockerfile": {
    "fileMatch": [
      "apps/.+/Dockerfile"
    ]
  },
  "ansible-galaxy": {
    "fileMatch": [
      "infra/ansible/requirements\\.yml$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "matchStrings": [
        "package:\\s*\"(?<depName>[^:]+):(?<currentValue>[^\\s\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "apps/**/Dockerfile",
        "**/*.compose.yaml"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "apps/**/Dockerfile"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z-]+)(?: depName=(?<depName>[^\\s]+))?(?: extractVersion=(?<extractVersion>[^\\s]+))?\\nARG [A-Z_]+=(?<currentValue>[^\\n]+)"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        ".github/workflows/deploy\\.yaml"
      ],
      "matchStrings": [
        "pip install ansible kubernetes infisicalsdk==(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "infisicalsdk",
      "datasourceTemplate": "pypi"
    }
  ],
  "platformAutomerge": true
}
