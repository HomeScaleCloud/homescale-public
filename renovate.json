{
  "extends": [
    "config:recommended"
  ],
  "baseBranches": [
    "main"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "pin",
        "digest",
        "patch"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": ["longhorn"],
      "automerge": false,
      "separateMultipleMinor": true
    },
    {
      "matchDepNames": ["vultr-kubernetes"],
      "automerge": false
    },
    {
      "matchManagers": ["terraform"],
      "semanticCommitScope": "infra"
    },
    {
      "matchManagers": ["argocd", "kubernetes", "dockerfile"],
      "semanticCommitScope": "apps"
    },
    {
      "matchManagers": ["github-actions"],
      "semanticCommitScope": "deps"
    },
    {
      "matchPackagePatterns": ["^ghcr\\.io/homescalecloud/"],
      "enabled": false
    }
  ],
  "argocd": {
    "fileMatch": [
      "apps/.+/[^/]+-argocd\\.yaml$"
    ]
  },
  "terraform": {
    "fileMatch": [
      "infra/terraform/.*\\.tf$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "apps/.+/.+\\.yaml$"
    ]
  },
  "github-actions": {
    "fileMatch": [
      ".gitea/workflows/.*\\.yaml$"
    ]
  },
  "dockerfile": {
    "fileMatch": [
      "apps/.+/Dockerfile"
    ]
  },
  "ansible-galaxy": {
    "fileMatch": [
      "infra/ansible/requirements\\.yml$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "matchStrings": [
        "package:\\s*\"(?<depName>[^:]+):(?<currentValue>[^\\s\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "apps/**/Dockerfile",
        "**/*.compose.yaml"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "apps/**/Dockerfile"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z-]+)(?: depName=(?<depName>[^\\s]+))?(?: extractVersion=(?<extractVersion>[^\\s]+))?\\nARG [A-Z_]+=(?<currentValue>[^\\n]+)"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        ".github/workflows/deploy\\.yaml"
      ],
      "matchStrings": [
        "pip install ansible kubernetes infisicalsdk==(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "infisicalsdk",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "apps/**/app\\.yaml"
      ],
      "matchStrings": [
        "repoURL:\\s*https://github\\.com/(?<depName>[^\\n\\s]+)\\n\\s+targetRevision:\\s*(?<currentValue>[^\\n\\s]+)"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "infra/terraform/main\\.tf"
      ],
      "matchStrings": [
        "k8s_version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "vultr-kubernetes",
      "datasourceTemplate": "custom.vultr-k8s",
      "versioningTemplate": "loose"
    }
  ],
  "customDatasources": {
    "vultr-k8s": {
      "defaultRegistryUrlTemplate": "https://api.vultr.com/v2/kubernetes/versions",
      "format": "json",
      "transformTemplates": [
        "{\"releases\": versions.{\"version\": $}}"
      ]
    }
  },
  "platformAutomerge": true
}
