{
  "grants": [
    // ==========================================
    // App Access
    // ==========================================

    // Rancher
    // mgmt
    {
      "src": [
        "group:team-infra-plat@REDACTED",
        "group:team-sec-plat@REDACTED"
      ],
      "dst": ["tag:app-rancher-mgmt"],
      "ip": ["tcp:443"]
    },

    // Home Assistant
    // prod
    {
      "src": ["group:Owners@REDACTED"],
      "dst": ["tag:app-ha-prod"],
      "ip": ["tcp:443"]
    },

    // Metrics
    // prod
    {
      "src": [
        "group:team-infra-plat@REDACTED",
        "group:team-sec-plat@REDACTED",
        "rainmitch.personal@outlook.com"
      ],
      "dst": ["tag:app-metrics"],
      "ip": ["tcp:443"]
    },

    // Untagged (low-risk) Apps
    {
      "src": ["autogroup:member"],
      "dst": ["tag:app"],
      "ip": ["tcp:443"]
    }
  ],
  "tagOwners": {
    "tag:app": ["tag:k8s"],

    "tag:app-rancher-mgmt": ["tag:env-mgmt"],
    "tag:app-ha-prod":      ["tag:env-prod"],
    "tag:app-metrics-prod":      ["tag:env-prod"]
  },
  "autoApprovers": {
    "services": {
      "tag:app": ["tag:app"],
      "tag:app-rancher-mgmt": ["tag:env-mgmt"],
      "tag:app-ha-prod": ["tag:env-prod"],
      "tag:app-metrics-prod": ["tag:env-prod"]
    }
  }
}
